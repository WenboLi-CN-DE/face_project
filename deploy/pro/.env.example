# 生产环境变量模板 — 实际 .env 文件不入库，从此模板复制后填写
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=640,640
FACE_GPU_ID=-1
FACE_THRESHOLD=0.55
FACE_IMAGES_BASE=/data/dataset
APP_PORT=8070
APP_WORKERS=2
LOG_LEVEL=INFO

# 活体检测阈值（可在请求中覆盖，这里是全局默认）
LIVENESS_THRESHOLD=0.5
ACTION_THRESHOLD=0.85

# 视频文件目录（docker 挂载路径，服务端接收的 video_path 必须在此目录下）
VIDEO_BASE_DIR=/app/videos

# API 鉴权（可选，取消注释并填写）
# API_TOKEN=your-secret-token-here

