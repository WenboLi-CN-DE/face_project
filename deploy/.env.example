# 环境变量模板 — 复制为 .env 后填写实际值
# 人脸识别模型配置
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=640,640
FACE_GPU_ID=-1
FACE_THRESHOLD=0.55
FACE_HIGH_THRESHOLD=0.70
FACE_LOW_THRESHOLD=0.40
FACE_IMAGES_BASE=/app/data/dataset

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8070
APP_WORKERS=2
LOG_LEVEL=INFO

# API 鉴权（可选，取消注释并填写）
# API_TOKEN=your-secret-token-here

# ───────────────────────────────────────────────────────────
# 静默活体检测配置（可选）
# ───────────────────────────────────────────────────────────

# 路径映射配置：外部路径=内部路径，多个用分号分隔
# 用于将客户端传入的路径映射到容器内实际路径
# 示例：远程服务器 /opt/test 映射到容器内 /data/videos
SILENT_PICTURE_PATHS=/opt/test=/data/videos;/opt/test2026=/data/videos

# 允许的路径前缀列表，用逗号分隔
# 只有匹配这些前缀的路径才会被接受（安全限制）
SILENT_ALLOWED_PATH_PREFIXES=/data/videos,/opt/test,/opt/test2026

