# 活体检测服务配置

# 回调地址（必须配置为宿主机 IP 或可访问的地址）
# 示例：LIVENESS_CALLBACK_URL=http://192.168.1.100:8092/api/v1/callbacks/liveness/action
LIVENESS_CALLBACK_URL=http://YOUR_HOST_IP:8092/api/v1/callbacks/liveness/action

# 回调签名密钥
LIVENESS_CALLBACK_SECRET=kyc-service-secret-key-2024

# 回调超时配置
LIVENESS_CALLBACK_TIMEOUT=10
LIVENESS_CALLBACK_MAX_RETRIES=3
LIVENESS_CALLBACK_RETRY_DELAY=2
